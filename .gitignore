.mypy_cache/
.ruff_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.gauge/

# Translations
*.mo
*.gmo

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
doc/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if delegates have different settings, Pipfile.lock might be changed.
#   Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock can be either ignored or checked-in, depending on Python project.
#   poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock can be either ignored or checked-in, depending on Python project.
#   pdm.lock

# virtualenv
.venv/
venv/
ENV/
env/
#   It's recommended to ignore these files:
#   pip-wheel-metadata/
#   .uv/

# IDE files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ZeroNet specific
*.log
